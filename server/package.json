{
  "name": "@vaultauth/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "pretest": "dotenv -e .env.test -- drizzle-kit push --config=drizzle.config.ts --force",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts --force",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "lint:staged": "lint-staged",
    "gen:keys": "node -e \"const crypto=require('crypto');const{privateKey,publicKey}=crypto.generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});const toBase64=(str)=>Buffer.from(str).toString('base64');console.log('JWT_PRIVATE_KEY='+toBase64(privateKey));console.log('');console.log('JWT_PUBLIC_KEY='+toBase64(publicKey));\"",
    "db:seed": "ts-node -e \"import('./src/db/seed').then(m => m.seedSystemData()).then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "dev:verify": "ts-node src/utils/dev-verify.ts",
    "dev:make-admin": "ts-node src/utils/dev-make-admin.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "argon2": "^0.31.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^4.28.0",
    "ioredis": "^5.3.0",
    "jose": "^5.0.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.20.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
