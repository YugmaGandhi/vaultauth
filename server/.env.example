# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3001

# ─── Database ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://griffon:password@localhost:5433/griffon_dev

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── JWT ──────────────────────────────────────────────────
# Generate RSA keypair by running this command from the server/ folder:
#
# node -e "
# const crypto = require('crypto');
# const { privateKey, publicKey } = crypto.generateKeyPairSync('rsa', {
#   modulusLength: 2048,
#   publicKeyEncoding: { type: 'spki', format: 'pem' },
#   privateKeyEncoding: { type: 'pkcs8', format: 'pem' }
# });
# const toBase64 = (str) => Buffer.from(str).toString('base64');
# console.log('JWT_PRIVATE_KEY=' + toBase64(privateKey));
# console.log('');
# console.log('JWT_PUBLIC_KEY=' + toBase64(publicKey));
# "
#
# Then paste the two output values below

# JWT
# Generate RSA keypair by running: npm run gen:keys
# Paste the output values below
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_ISSUER=griffon

# ─── Email ────────────────────────────────────────────────
# For local development Mailpit catches all emails
# Open http://localhost:8025 to view them
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@griffon.dev
EMAIL_FROM_NAME=Griffon
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# For production with Resend:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key

# ─── App URL ───────────────────────────────────────────────
# Used to generate links in emails
APP_BASE_URL=http://localhost:3000

# ─── Organizations ─────────────────────────────────────────
# Set to false to restrict org creation to super-admins only
ALLOW_ORG_CREATION=true
# Maximum number of organizations a single user can create
MAX_ORGS_PER_USER=10

# ─── OAuth Providers ───────────────────────────────────────
# Only fill in the providers you want to enable
# Leaving a provider's credentials empty disables it automatically
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
OAUTH_SUCCESS_REDIRECT=http://localhost:3001/dashboard
OAUTH_FAILURE_REDIRECT=http://localhost:3001/login

# Webhooks — AES-256-GCM key for encrypting webhook signing secrets at rest.
# Required: 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
# Never commit a real key. Never reuse this placeholder in any environment.
WEBHOOK_SECRET_KEY=__REPLACE_WITH_64_HEX_CHARS__

# MFA — AES-256-GCM key for encrypting TOTP secrets at rest.
# Required: 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
# Must be a different key from WEBHOOK_SECRET_KEY in production.
MFA_ENCRYPTION_KEY=__REPLACE_WITH_64_HEX_CHARS__

# API Keys — maximum active (non-revoked and non-expired) API keys per user.
MAX_API_KEYS_PER_USER=10

# Google — https://console.cloud.google.com
# Create OAuth 2.0 credentials, add redirect URI:
# http://localhost:3000/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/applications/new
# Set callback URL to: http://localhost:3000/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft — https://portal.azure.com
# Set redirect URI to: http://localhost:3000/auth/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=