# ─── Test Environment ─────────────────────────────────────
# This file is committed to git — never put real credentials here
# JWT keys are injected by CI via GitHub Secrets
NODE_ENV=test
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=error
CORS_ORIGINS=http://localhost:3001

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://vaultauth:password@localhost:5433/vaultauth_test

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── JWT ──────────────────────────────────────────────────
# Real keys injected via GitHub Secrets in CI
# For local test runs, generate with: npm run gen:keys
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=30d
# JWT_ISSUER=vaultauth

# ─── Email ────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@vaultauth.dev
EMAIL_FROM_NAME=VaultAuth
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
APP_BASE_URL=http://localhost:3000

# ─── Organizations ────────────────────────────────────────
ALLOW_ORG_CREATION=true
MAX_ORGS_PER_USER=10

# ─── OAuth ────────────────────────────────────────────────
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
OAUTH_SUCCESS_REDIRECT=http://localhost:3001/dashboard
OAUTH_FAILURE_REDIRECT=http://localhost:3001/login
# OAuth providers intentionally empty in test environment
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=