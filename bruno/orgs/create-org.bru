meta {
  name: Create Organization
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/orgs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Acme Corp",
    "slug": "acme-corp"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("orgId", res.body.data.organization.id);
  }
}
